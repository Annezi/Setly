# Скопируйте в .env и заполните. Не коммитьте .env в git.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=postgres
POSTGRES_HOST=database
CORS_ORIGINS=https://setly.space,http://localhost:3000

# Публичный URL API (для ссылок на загруженные файлы: обложки, аватары). В проде: https://api.setly.space
# API_PUBLIC_URL=https://api.setly.space

# Фронтенд (см. также setly.front/.env.example):
# NEXT_PUBLIC_SITE_URL=https://setly.space
# NEXT_PUBLIC_API_URL=https://api.setly.space

# Обязательно. Один и тот же секрет на всех инстансах API. Смена = все токены недействительны (все выходят).
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=08f1357da6d2b7b56d6c8ec215ca076f

# SMTP для писем восстановления пароля
# MAIL_SMTP_HOST=smtp.your-provider.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_USER=mailer@setly.space
# MAIL_SMTP_PASSWORD=your_password
# MAIL_SMTP_STARTTLS=1
# MAIL_SMTP_SSL=0
# MAIL_FROM_EMAIL=no-reply@setly.space
# MAIL_FROM_NAME=Setly
# PASSWORD_RESET_TOKEN_TTL_MINUTES=1440
# APP_TIMEZONE=Europe/Moscow

# Telegram: уведомления о заявках на публикацию (модерация). Без токена/чата — уведомления не шлются.
# TELEGRAM_BOT_TOKEN=123456:ABC...
# ID чата (личка с ботом: положительное; группа: обычно отрицательное)
# TELEGRAM_MODERATION_CHAT_ID=-1001234567890
# Секрет в URL вебхука: https://api.setly.space/api/telegram/webhook/<секрет>
# TELEGRAM_WEBHOOK_SECRET=openssl_rand_hex_32
# Необязательно: кто может нажимать кнопки (через запятую, Telegram user id). Пусто = любой в чате
# TELEGRAM_MODERATION_USER_IDS=12345,67890
# Кто пишется в audit log (0 = система)
# TELEGRAM_AUDIT_ADMIN_USER_ID=0
