setly.front/node_modules/
setly.front/.pnp
setly.front/.pnp.*
setly.front/.next/
setly.front/out/
setly.front/build/
setly.front/.vercel
setly.front/*.tsbuildinfo
setly.front/next-env.d.ts
setly.front/npm-debug.log*
setly.front/yarn-debug.log*
setly.front/yarn-error.log*
setly.front/.pnpm-debug.log*
