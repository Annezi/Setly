# Backend
backend/__pycache__
backend/**/__pycache__
backend/env/
backend/*.pyc
backend/storage/*
!backend/storage/.gitkeep
!backend/storage/**/.gitkeep

# Database & local data
db/

# Root Python venv
env/
node_modules/

# --- Secrets & credentials (never commit) ---
# Environment files (шаблоны *.example остаются в репозитории)
.env
.env.*
!.env.example
!**/.env.example

backend/.env
backend/.env.*
!backend/.env.example

setly.front/.env
setly.front/.env.*
!setly.front/.env.example

setly.admin/.env
setly.admin/.env.*
!setly.admin/.env.example

# TLS / SSH / keystores
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.ppk

# OAuth, cloud, service accounts
credentials.json
credentials*.json
*-credentials.json
service-account*.json
google-services.json
GoogleService-Info.plist
.local.settings.json
.aws/
.gcp/

# Docker / proxy secrets
docker-compose.override.yml
docker-compose.*.local.yml
acme.json
**/acme.json
.htpasswd

# App data with passwords or tokens (legacy dev)
**/users.json
secrets/
*.secret
.secrets

# npm/yarn tokens
.npmrc
.yarnrc.yml.local

# DB dumps & local database files (не сиды в backend/database/)
*-dump.sql
*-backup.sql
*.sql.gz
*.dump
*.sqlite
*.sqlite3

