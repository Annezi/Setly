# Скопируйте в `.env.local` или `.env`. Значения ниже подходят для продакшена setly.space.

# Канонический адрес сайта (og:url, абсолютные ссылки в метаданных).
NEXT_PUBLIC_SITE_URL=https://setly.space

# Публичный URL API — браузер и абсолютные URL картинок в OG (api.setly.space/storage/...).
NEXT_PUBLIC_API_URL=https://api.setly.space

# --- Только Docker / прод-сервер Next (runtime, не NEXT_PUBLIC): ---
# Запросы generateMetadata к API из контейнера фронта.
# В docker-compose уже задаётся API_INTERNAL_URL=http://setly-api:8000
# При необходимости переопределите:
# API_INTERNAL_URL=http://setly-api:8000

# Явный URL только для SSR-метаданных (если не хотите использовать API_INTERNAL_URL):
# METADATA_API_URL=http://setly-api:8000
